{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "metadata.schema.json",
  "title": "Benchmark Case Metadata",
  "type": "object",
  "required": [
    "case_id",
    "task_type",
    "web_policy",
    "target_image_type",
    "difficulty",
    "env_files"
  ],
  "additionalProperties": false,
  "properties": {
    "case_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*_[0-9]{3}$"
    },
    "task_type": {
      "type": "string",
      "enum": [
        "data_selection",
        "data_insight",
        "document_brief",
        "design_specification",
        "procedure_instruction",
        "relationship_diagram",
        "state_change",
        "multi_source_fusion"
      ]
    },
    "web_policy": {
      "type": "string",
      "enum": [
        "closed_env",
        "web_required",
        "web_helpful"
      ]
    },
    "target_image_type": {
      "type": "string",
      "minLength": 3
    },
    "difficulty": {
      "type": "string",
      "enum": [
        "easy",
        "medium",
        "hard"
      ]
    },
    "env_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "path",
          "role"
        ],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "minLength": 3
          },
          "format": {
            "type": "string",
            "minLength": 2
          },
          "origin": {
            "type": "string",
            "enum": [
              "generated",
              "manual",
              "public_download",
              "public_crawl",
              "derived",
              "mixed",
              "downloaded",
              "generated_from_source_excerpt"
            ]
          },
          "source_url": {
            "type": "string"
          },
          "retrieved_at": {
            "type": "string"
          },
          "license_note": {
            "type": "string"
          },
          "reproducibility_note": {
            "type": "string"
          },
          "conversion_note": {
            "type": "string"
          },
          "local_path": {
            "type": "string"
          },
          "asset_path": {
            "type": "string"
          },
          "whether_original_or_adapted": {
            "type": "string"
          },
          "text_extract_check": {
            "type": "string"
          },
          "page_count": {
            "type": "integer",
            "minimum": 1
          },
          "adaptation_note": {
            "type": "string"
          }
        }
      }
    },
    "source_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "agent_visible_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evaluator_only_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "web_usage_note": {
          "type": "string"
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
